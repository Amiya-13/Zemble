# MongoDB Atlas Connection Template
# Follow these steps to update your .env file:

# 1. Get your connection string from MongoDB Atlas:
#    - Click "Connect" on Fastcom cluster
#    - Choose "Connect your application"
#    - Select Node.js driver
#    - Copy the connection string

# 2. Replace <username> with your database username
# 3. Replace <password> with your actual password
# 4. Replace xxxxx with your cluster identifier from Atlas
# 5. The /zemble at the end specifies your database name

MONGODB_URI=mongodb+srv://<username>:<password>@fastcom.xxxxx.mongodb.net/zemble?retryWrites=true&w=majority
PORT=5000
JWT_SECRET=zembl-secret-key-change-in-production-please-use-strong-secret
NODE_ENV=development

# EXAMPLE (with fake credentials):
# MONGODB_URI=mongodb+srv://myuser:MyPass123@fastcom.abcd123.mongodb.net/zemble?retryWrites=true&w=majority

# IMPORTANT NOTES:
# - If your password has special characters (@, #, %, etc.), URL-encode them
# - No quotes around the connection string
# - No spaces around the = sign
# - Keep this file secure - never commit to git!
